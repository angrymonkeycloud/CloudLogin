@rendermode @(new InteractiveWebAssemblyRenderMode(true))

@namespace AngryMonkey.CloudLogin

@if (!RendererInfo.IsInteractive)
{

    <div class="pageloading">
        <div class="pageloading-logo">
            <img src="/logo.svg?v=1" />
        </div>
        <div class="pageloading-progress">
            <span></span>
        </div>
    </div>
}
else
{
    <section>
        <article>
            <AngryMonkey.CloudLogin.AccountComponent  Referer="@Referer"/>
        </article>
    </section>
}

@code{
    [Parameter] public string? Referer { get; set; }
}